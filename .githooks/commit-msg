#!/usr/bin/env bash
# commit-msg-Hook — Traceability-Gate (AGENTS.md §5; slice-008).
#
# Verlangt mindestens eine AC-/ADR-/MR-/slice-ID in der Commit-Message
# (harness/README.md §Traceability rules). Installiert via `make hooks`
# (git config core.hooksPath .githooks) — opt-in pro Klon; die
# klon-unabhängige Kontrolle ist der CI-Range-Check (.github/workflows/ci.yml).
#
# EINE Wahrheit: ruft dasselbe Skript wie CI und `make trace-check`.
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"
exec bash tools/trace-check.sh --message "$1"
